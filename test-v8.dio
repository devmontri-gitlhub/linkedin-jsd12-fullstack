                <mxCell id="218" value="&lt;div&gt;&lt;font color=&quot;#000000&quot;&gt;frontend/&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font color=&quot;#000000&quot;&gt;├── index.html&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font color=&quot;#000000&quot;&gt;├── src/&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font color=&quot;#000000&quot;&gt;│&amp;nbsp; &amp;nbsp;├── main.jsx&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;# Entry point ของ React&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font color=&quot;#000000&quot;&gt;│&amp;nbsp; &amp;nbsp;├── App.jsx&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; # จัดการ Routing หลัก&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font color=&quot;#000000&quot;&gt;│&amp;nbsp; &amp;nbsp;├── layouts/&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font color=&quot;#000000&quot;&gt;│&amp;nbsp; &amp;nbsp;│&amp;nbsp; &amp;nbsp;└── MainLayout.jsx&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;# โครงสร้าง Layout หลักของหน้าเว็บ&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font color=&quot;#000000&quot;&gt;│&amp;nbsp; &amp;nbsp;├── pages/&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font color=&quot;#000000&quot;&gt;│&amp;nbsp; &amp;nbsp;│&amp;nbsp; &amp;nbsp;├── ExplainPage.jsx&amp;nbsp; &amp;nbsp; &amp;nbsp; # หน้าอธิบายโปรเจกต์&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font color=&quot;#000000&quot;&gt;│&amp;nbsp; &amp;nbsp;│&amp;nbsp; &amp;nbsp;├── AdminDashboardPage.jsx # หน้า Dashboard สำหรับแอดมิน&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font color=&quot;#000000&quot;&gt;│&amp;nbsp; &amp;nbsp;│&amp;nbsp; &amp;nbsp;└── AboutMePage.jsx&amp;nbsp; &amp;nbsp; &amp;nbsp; # หน้าเกี่ยวกับฉัน&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font color=&quot;#000000&quot;&gt;│&amp;nbsp; &amp;nbsp;├── components/&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font color=&quot;#000000&quot;&gt;│&amp;nbsp; &amp;nbsp;│&amp;nbsp; &amp;nbsp;├── UserManagement.jsx&amp;nbsp; &amp;nbsp;# คอมโพเนนต์จัดการผู้ใช้งาน&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font color=&quot;#000000&quot;&gt;│&amp;nbsp; &amp;nbsp;│&amp;nbsp; &amp;nbsp;├── AdminManagement.jsx&amp;nbsp; # คอมโพเนนต์จัดการแอดมิน&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font color=&quot;#000000&quot;&gt;│&amp;nbsp; &amp;nbsp;│&amp;nbsp; &amp;nbsp;└── AdminLogin.jsx&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;# คอมโพเนนต์ฟอร์มล็อกอิน&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font color=&quot;#000000&quot;&gt;│&amp;nbsp; &amp;nbsp;└── services/&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; # Service Layer (API Client) จัดการยิง Request&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font color=&quot;#000000&quot;&gt;│&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;├── UserService.js&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font color=&quot;#000000&quot;&gt;│&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;├── Admin_Auth_Service.js # จุดเชื่อมต่อ API ตรวจสอบ Success/Error&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font color=&quot;#000000&quot;&gt;│&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;└── admin.service.js&amp;nbsp; &amp;nbsp; &amp;nbsp;# ✨ [เพิ่มเข้ามา] จัดการ API การทำงานต่างๆ ของฝั่ง Admin&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font color=&quot;#000000&quot;&gt;└── package.json&lt;/font&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
                    <mxGeometry x="210" y="160" width="480" height="300" as="geometry"/>
                </mxCell>
